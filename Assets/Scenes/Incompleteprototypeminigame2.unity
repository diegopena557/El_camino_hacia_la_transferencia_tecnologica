    - target: {fileID: 6126194440746097761, guid: aa3fb00fd24e61f498cbfa8f3005f7fd, type: 3}
      propertyPath: levelUI
      value: 
      objectReference: {fileID: 1823861339}
    - target: {fileID: 6126194440746097761, guid: aa3fb00fd24e61f498cbfa8f3005f7fd, type: 3}
      propertyPath: levels.Array.data[0].levelDescription
      value: "En esta fase buscamos comprender los principios que explican c\xF3mo
        funciona una idea.\nA\xFAn no construimos soluciones: observamos y analizamos
        el fen\xF3meno que hace posible la tecnolog\xEDa.\n\nUtiliza las fichas que
        te ayuden a comprender el problema."
      objectReference: {fileID: 0}
    - target: {fileID: 6126194440746097761, guid: aa3fb00fd24e61f498cbfa8f3005f7fd, type: 3}
      propertyPath: levels.Array.data[1].levelDescription
      value: "Ahora que entendemos el fen\xF3meno, podemos empezar a imaginar c\xF3mo
        convertirlo en una tecnolog\xEDa.\nEn esta fase se formulan conceptos, posibles
        aplicaciones y primeras ideas de soluci\xF3n.\n\nUtiliza las fichas que te
        permitan proponer c\xF3mo podr\xEDa funcionar la tecnolog\xEDa."
      objectReference: {fileID: 0}
    - target: {fileID: 6126194440746097761, guid: aa3fb00fd24e61f498cbfa8f3005f7fd, type: 3}
      propertyPath: levels.Array.data[2].levelDescription
      value: "En esta fase la idea deja de ser solo un concepto y comienza a ponerse
        a prueba.\nSe realizan experimentos iniciales para comprobar si el principio
        funciona en la pr\xE1ctica.\n\nUtiliza las fichas que te ayuden a poner a
        prueba la idea y observar sus resultados."
      objectReference: {fileID: 0}
    - target: {fileID: 6637735141933939293, guid: aa3fb00fd24e61f498cbfa8f3005f7fd, type: 3}
      propertyPath: audioSource
      value: 
      objectReference: {fileID: 2056250223}
